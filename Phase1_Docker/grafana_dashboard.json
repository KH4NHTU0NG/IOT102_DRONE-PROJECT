          "query": "from(bucket: \"drone_data\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"drone_telemetry\")\n  |> filter(fn: (r) => r[\"_field\"] == \"wifi_rssi\")\n  |> last()",
          "refId": "A"
